{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TichPhong Share",
  "version": "2.0.1",
  "identifier": "vn.tichphong.share",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TichPhong Share",
        "width": 800,
        "height": 650,
        "decorations": false,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
  },
  "bundle": {
    "active": true,
    "windows": {
      "nsis": {
        "template": "windows/installer.nsi",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "installerHooks": "windows/hooks.nsh"
      },
      "wix": {
        "bannerPath": "icons/wix-banner.bmp",
        "dialogImagePath": "icons/wix-dialog.bmp"
      }
    },
    "targets": ["deb", "rpm", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "TichPhongOS Team",
    "copyright": "Copyright © 2026 TichPhong OS Team. All rights reserved.",
    "shortDescription": "Ứng dụng chia sẻ file nhanh chóng đa nền tảng cho TichPhongOS",
    "longDescription": "TichPhong Share là một ứng dụng chia sẻ file đa nền tảng (PC, Mobile) bảo mật, nhanh chóng dựa trên giao thức Quick Share và LocalSend.",
    "category": "Utility"
  }
}
